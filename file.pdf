    <script type="text/javascript">
        function PrintPanel() {
            debugger;
            var panel = document.getElementById("PnlShowResult");
   
             var printWindow = window.open('', '', 'height=100%,width=800');

             printWindow.document.write('<html><head>');
             printWindow.document.write('</head><body>');

             printWindow.document.write('<p id="Interimid" style="-webkit-transform: rotate(331deg);-moz-transform: rotate(331deg); -o-transform: rotate(331deg); transform: rotate(331deg);font-size: 8em;color: rgba(255, 5, 5, 0.17);position: absolute; top:20%;left:30%;text-transform:uppercase;">INTERIM</p>');

             printWindow.document.write(panel.innerHTML);

             printWindow.document.write('</body></html>');
             printWindow.document.close();

             setTimeout(function () {
                 printWindow.print();
             }, 500);
             return false;
         }
        function PrintPanelWithoiutInterim() {
            debugger;
            var panel = document.getElementById("PnlShowResult");

          var printWindow = window.open('', '', 'height=100%,width=800');

          printWindow.document.write('<html><head>');
          printWindow.document.write('</head><body>');

          printWindow.document.write(panel.innerHTML);

          printWindow.document.write('</body></html>');
          printWindow.document.close();

          setTimeout(function () {
              printWindow.print();
          }, 500);
          return false;
      }
    </script>

    <script src="plugins/jQuery/jQuery-2.2.0.min.js"></script>
