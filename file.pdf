    <style>
        .content-text {
            color: #fff;
            display: flex;
            padding: 10px;
            justify-content: center;
        }

            .content-text .logo-img {
                height: 70px;
                height: 70px;
            }

        .inner-content {
            padding-left: 10px;
        }

            .inner-content h2 {
                margin: 0;
            }

        .heading {
            background-color: #015293;
            color: #fff;
            padding: 10px 20px;
            margin-top: 0px;
        }

        .form-body {
            border: 1px solid #bbb;
            margin: 30px;
            padding: 0;
        }

        .form-result {
            margin: 20px 0 0 0;
        }
        /*.main-footer {
            background-color:#015293;
            color:#fff;
        }*/
        @media only screen and (max-width:767px) {
            .form-body {
                margin: 10px !important;
            }
        }

        .rotingtxt {
            -webkit-transform: rotate(331deg);
            -moz-transform: rotate(331deg);
            -o-transform: rotate(331deg);
            transform: rotate(331deg);
            font-size: 8em;
            color: rgba(255, 5, 5, 0.17);
            position: absolute;
            top: 20%;
            left: 30%;
            font-family: 'Denk One', sans-serif;
            text-transform: uppercase;
        }

        .mytable {
            position: relative;
        }
    </style>

    
